rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissao == 'administrador'
      );
    }

    // Regra do Usuário: Cada usuário lê e escreve seu próprio nó /users/{userId} ou o administrador
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      // Subcoleções do usuário (financialData, expenses, cards, investments, alerts)
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Logs de auditoria do sistema
    match /auditLogs/{logId} {
      allow read, write: if isSignedIn();
    }

    // Bloqueio padrão para rotas não mapeadas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
